#!/bin/zsh
set -euo pipefail

APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
SCRIPT_FILE="$APP_DIR/mac_cleaner.py"
PYTHON_BIN="/usr/bin/python3"

if [ -x "$APP_DIR/.venv/bin/python" ]; then
  PYTHON_BIN="$APP_DIR/.venv/bin/python"
fi

if [ ! -f "$SCRIPT_FILE" ]; then
  osascript -e 'display alert "앱클리너" message "mac_cleaner.py 파일을 찾을 수 없습니다."'
  exit 1
fi

exec "$PYTHON_BIN" "$SCRIPT_FILE" --gui
